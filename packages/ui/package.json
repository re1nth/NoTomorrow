{
  "name": "@notomorrow/ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./tailwind": {
      "types": "./src/tailwind.preset.ts",
      "default": "./src/tailwind.preset.ts"
    },
    "./lottie/ko-stamp.json": "./src/lottie/ko-stamp.json",
    "./lottie/bell-ring.json": "./src/lottie/bell-ring.json",
    "./lottie/punch-swoosh.json": "./src/lottie/punch-swoosh.json"
  },
  "files": ["src", "dist"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^3.4.0",
    "framer-motion": "^11.0.0",
    "lottie-react": "^2.4.0"
  },
  "dependencies": {
    "@notomorrow/domain": "workspace:*"
  },
  "devDependencies": {
    "@storybook/addon-essentials": "^8.4.0",
    "@storybook/react": "^8.4.0",
    "@storybook/react-vite": "^8.4.0",
    "@types/node": "^20.17.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "framer-motion": "^11.0.0",
    "lottie-react": "^2.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "storybook": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.7.2",
    "vite": "^5.4.0"
  }
