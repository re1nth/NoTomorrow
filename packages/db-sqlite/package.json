{
  "name": "@notomorrow/db-sqlite",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./schema": {
      "types": "./src/schema/index.ts",
      "default": "./src/schema/index.ts"
    },
    "./client": {
      "types": "./src/client.ts",
      "default": "./src/client.ts"
    },
    "./migrate": {
      "types": "./src/migrate.ts",
      "default": "./src/migrate.ts"
    }
  },
  "files": ["src", "migrations"],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "migrate:gen": "drizzle-kit generate"
  },
  "dependencies": {
    "better-sqlite3": "^11.5.0",
    "drizzle-orm": "^0.36.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.16.0",
    "drizzle-kit": "^0.28.1",
    "typescript": "^5.7.2"
  }
}
